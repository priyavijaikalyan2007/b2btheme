{
  "name": "enterprise-bootstrap-theme",
  "version": "1.0.0",
  "description": "Compact, professional Bootstrap theme for enterprise SaaS applications",
  "main": "dist/css/custom.css",
  "scripts": {
    "scss": "sass --no-source-map --quiet-deps --silence-deprecation=import --silence-deprecation=global-builtin --silence-deprecation=color-functions --silence-deprecation=if-function src/scss:dist/css",
    "css": "postcss dist/css/custom.css --replace",
    "build:css": "npm-run-all scss css",
    "watch:scss": "sass --watch --no-source-map --quiet-deps --silence-deprecation=import --silence-deprecation=global-builtin --silence-deprecation=color-functions --silence-deprecation=if-function src/scss:dist/css",
    "build:ts": "bash scripts/bundle-diagramengine.sh && tsc && bash scripts/wrap-iife.sh && bash scripts/minify-js.sh",
    "build:icons": "mkdir -p dist/icons && cp -R node_modules/bootstrap-icons/font/* dist/icons/ && sed -i 's/font-display: block/font-display: swap/' dist/icons/bootstrap-icons.css",
    "build:components:css": "sass --no-source-map --quiet-deps --silence-deprecation=import --silence-deprecation=global-builtin --silence-deprecation=color-functions --silence-deprecation=if-function components/:dist/components/ && bash scripts/minify-component-css.sh",
    "generate:docs": "node scripts/generate-docs.js",
    "copy:docs": "bash scripts/copy-docs.sh",
    "build:docs": "npm run generate:docs && npm run copy:docs",
    "build:info": "bash scripts/build-info.sh",
    "build": "npm run build:css && npm run build:ts && npm run build:components:css && npm run build:icons && npm run copy:js && npm run build:docs && npm run build:info",
    "copy:js": "mkdir -p dist/js && cp node_modules/bootstrap/dist/js/bootstrap.bundle.min.js* dist/js/",
    "watch": "npm run watch:scss",
    "dev": "npm run build && npm run watch",
    "deploy": "npx wrangler deploy",
    "test": "npm run test:unit && npm run test:structure",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:structure": "bash test-local.sh",
    "test:cdn": "bash test-cdn.sh",
    "test:all": "npm run test:unit && npm run test:e2e && npm run test:structure"
  },
  "keywords": [
    "bootstrap",
    "theme",
    "enterprise",
    "saas",
    "compact",
    "professional"
  ],
  "author": "pvk2007",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/priyavijaikalyan2007/b2btheme.git"
  },
  "homepage": "https://theme.priyavijai-kalyan2007.workers.dev/",
  "bugs": {
    "url": "https://github.com/priyavijaikalyan2007/b2btheme/issues"
  },
  "overrides": {
    "undici": ">=7.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.21",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "cssnano": "^7.1.3",
    "jsdom": "^29.0.0",
    "marked": "^17.0.1",
    "npm-run-all": "^1.1.3",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "sass": "^1.93.2",
    "terser": "^5.46.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  }
}
