{
  "name": "enterprise-bootstrap-theme",
  "version": "1.0.0",
  "description": "Compact, professional Bootstrap theme for enterprise SaaS applications",
  "main": "dist/css/custom.css",
  "scripts": {
    "scss": "sass --no-source-map --quiet-deps --silence-deprecation=import --silence-deprecation=global-builtin --silence-deprecation=color-functions src/scss:dist/css",
    "css": "postcss dist/css/custom.css --replace --use autoprefixer",
    "build:css": "npm-run-all scss css",
    "watch:scss": "sass --watch --no-source-map --quiet-deps --silence-deprecation=import --silence-deprecation=global-builtin --silence-deprecation=color-functions src/scss:dist/css",
    "build:ts": "tsc && sed -i 's/^export class /class /; s/^export function /function /' dist/components/errordialog/errordialog.js",
    "build:icons": "mkdir -p dist/icons && cp -R node_modules/bootstrap-icons/font/* dist/icons/",
    "build:components:css": "sass --no-source-map --quiet-deps --silence-deprecation=import --silence-deprecation=global-builtin --silence-deprecation=color-functions components/:dist/components/",
    "build": "npm run build:css && npm run build:ts && npm run build:components:css && npm run build:icons && npm run copy:js",
    "copy:js": "mkdir -p dist/js && cp node_modules/bootstrap/dist/js/bootstrap.bundle.min.js* dist/js/",
    "watch": "npm run watch:scss",
    "dev": "npm run build && npm run watch",
    "deploy": "npx wrangler deploy"
  },
  "keywords": [
    "bootstrap",
    "theme",
    "enterprise",
    "saas",
    "compact",
    "professional"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "sass": "^1.93.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.53.0"
  },
  "dependencies": {
    "wrangler": "^4.53.0"
  }
}
