{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "moduleResolution": "node",
        "strict": true,
        "declaration": true,
        "outDir": "dist/components",
        "rootDir": "components",
        "sourceMap": false,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "noUnusedLocals": false,
        "noUnusedParameters": false
    },
    "include": [
        "components/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/*.test.ts",
        "components/diagramengine/src/**"
    ]
}
